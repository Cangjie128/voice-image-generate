.profile-hero {
  display: flex;
  align-items: center;
  min-height: 180rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fff0f3 0%, #fff9e8 100%);
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #e85d75;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 800;
}

.profile-main {
  flex: 1;
  margin-left: 22rpx;
  min-width: 0;
}

.nickname,
.profile-note,
.bind-label,
.bind-code,
.date-title,
.date-subtitle,
.switch-title,
.switch-desc {
  display: block;
}

.nickname {
  color: #332a2a;
  font-size: 38rpx;
  font-weight: 800;
}

.profile-note {
  margin-top: 8rpx;
  color: #786966;
  font-size: 26rpx;
}

.bind-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx;
}

.bind-label {
  color: #8f7d7a;
  font-size: 24rpx;
}

.bind-code {
  margin-top: 6rpx;
  color: #d7556d;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.info-card,
.switch-card {
  padding: 6rpx 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 86rpx;
  border-bottom: 1rpx solid #f3e4df;
  gap: 24rpx;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row text:first-child {
  min-width: 150rpx;
  color: #8f7d7a;
}

.info-row text:last-child {
  flex: 1;
  color: #332a2a;
  text-align: right;
}

.date-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.date-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.date-title {
  color: #332a2a;
  font-size: 28rpx;
  font-weight: 800;
}

.date-subtitle {
  margin-top: 6rpx;
  color: #8f7d7a;
  font-size: 24rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 112rpx;
  border-bottom: 1rpx solid #f3e4df;
  gap: 22rpx;
}

.switch-row:last-child {
  border-bottom: none;
}

.switch-row view {
  flex: 1;
}

.switch-title {
  color: #332a2a;
  font-size: 28rpx;
  font-weight: 700;
}

.switch-desc {
  margin-top: 4rpx;
  color: #8f7d7a;
  font-size: 23rpx;
}

.about-card {
  margin-top: 30rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #f5fbf8;
  color: #55766b;
  font-size: 24rpx;
}

.role-reset-btn {
  width: 100%;
  margin-top: 20rpx;
}
